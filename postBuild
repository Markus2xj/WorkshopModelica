#!/bin/bash
# Runs once when Binder builds the image. Pre-compiles the FMU's platform
# binary so the first simulation in the notebook is instant. Safe to skip
# if the FMU already ships a linux64 binary.
set -e

python - <<'PY'
import os
fmu = "Standalone_House.fmu"
if not os.path.exists(fmu):
    print("postBuild: no FMU found, skipping pre-compile.")
else:
    try:
        from fmpy.util import compile_platform_binary
        compile_platform_binary(fmu)
        print("postBuild: pre-compiled FMU platform binary.")
    except Exception as e:
        print(f"postBuild: could not pre-compile ({e}); "
              f"FMPy will compile on first run instead.")
PY
