#!/bin/bash
# Runs once when Binder builds the image. Pre-compiles the FMU's platform
# binary so the first simulation in the notebook is instant. Safe to skip
# if the FMU already ships a linux64 binary.
set -e

if [ -f "Standalone_House.fmu" ]; then
    echo "postBuild: compiling FMU platform binary..."
    python -m fmpy compile Standalone_House.fmu
    echo "postBuild: done."
else
    echo "postBuild: no FMU found, skipping."
fi
